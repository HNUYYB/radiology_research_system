# ============================================================
# 放射学研究方案生成系统 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值，切勿将 .env 提交到版本控制
# ============================================================

# ── 安全密钥（生产环境必须修改） ──
SECRET_KEY=your-flask-secret-key-here-change-me
JWT_SECRET_KEY=your-jwt-secret-key-here-change-me
JWT_ACCESS_TOKEN_EXPIRES=86400

# ── LLM 模型提供商选择 (longcat / deepseek / openai) ──
LLM_PROVIDER=longcat

# ── LongCat / Anthropic API (默认) ──
ANTHROPIC_API_KEY=your-longcat-api-key-here
ANTHROPIC_BASE_URL=https://api.longcat.chat/anthropic
ANTHROPIC_MODEL=LongCat-2.0-Preview

# ── DeepSeek API (可选) ──
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI API (可选) ──
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── PubMed API（可选，但强烈建议配置以提高搜索额度） ──
PUBMED_API_KEY=your-pubmed-api-key-here
PUBMED_EMAIL=your-email@example.com

# ── 应用配置 ──
FLASK_DEBUG=True
PORT=5002
LOG_LEVEL=INFO

# ── 数据库（可选，默认使用 instance/research_system.db） ──
# DATABASE_URL=sqlite:///absolute/path/to/your.db
