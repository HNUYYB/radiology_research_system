   },\n    {\n      \"method\": \"跨模态深度学习融合（Cross-modal Deep Learning）\",\n      \"description\": \"构建双流网络分别处理CT与PET图像（或CT与临床数据），通过注意力机制或多层融合层（如concat、element-wise product）整合多模态特征。\",\n      \"source_paper\": \"[3]\",\n      \"applicability\": \"适用于PET/CT数据集；若能结合临床变量（年龄、性别、吸烟史等）可进一步构建三级融合模型\"\n    },\n    {\n      \"method\": \"多模态Nomogram融合（Radiomics + DL + Clinical）\",\n      \"description\": \"提取影像组学特征与深度学习深度特征，通过多变量Cox回归筛选，与临床变量联合构建列线图（Nomogram），进行风险分层。\",\n      \"source_paper\": \"[4]\",\n      \"applicability\": \"可作为基准模型；建议使用深度学习特征替代部分手工影像组学，并采用LASSO-Cox进行特征筛选以增强可解释性\"\n    },\n    {\n      \"method\": \"风险分层与递归特征消除（Radiomic risk stratification）\",\n      \"description\": \"通过影像组学特征构建复发风险评分，结合临床病理因素进行多因素分析，并绘制Kaplan-Meier曲线区分高低风险组。\",\n      \"source_paper\": \"[5]\",\n      \"applicability\": \"可借鉴其构建风险分组的方法，但需将终点修改为总生存期；可引入时间依赖性AUC和C-index评估\"\n    },\n    {\n      \"method\": \"放射基因组学整合模型（Radiogenomics）\",\n      \"description\": \"将影像组学特征与基因组学特征（如糖代谢基因标签）进行关联分析，并通过多元模型预测预后。\",\n      \"source_paper\": \"[6]\",\n      \"applicability\": \"若无法获取基因数据，可仅采用影像组学+深度学习特征模拟，或与公共数据库的基因表达数据进行关联分析\"\n    }\n  ]\n}",
